    "label.inst_iphone": {
      "es": "📲 Instalar en iPhone",
      "en": "📲 Install on iPhone"
    },
    "label.inst_iphone_steps": {
      "es": "Sigue estos pasos para instalar esta aplicación en la pantalla de inicio de tu iPhone:",
      "en": "Follow these steps to install this app on your iPhone's home screen:"
    },
    "label.inst_iphone_step1": {
      "es": "Abre el navegador <strong>Safari</strong> en tu iPhone e ingresa a este sitio web.",
      "en": "Open the <strong>Safari</strong> browser on your iPhone and go to this website."
    },
    "label.inst_iphone_step2": {
      "es": "Toca el botón <strong>Compartir</strong> <span style=\"font-size: 1.2rem;\">📤</span> (el icono de caja con flecha hacia arriba) en la barra de navegación inferior de Safari.",
      "en": "Tap the <strong>Share</strong> button <span style=\"font-size: 1.2rem;\">📤</span> (the box icon with an arrow pointing up) in Safari's bottom navigation bar."
    },
    "label.inst_iphone_step3": {
      "es": "Desplázate hacia abajo en el menú y selecciona la opción <strong>\"Agregar a pantalla de inicio\"</strong>.",
      "en": "Scroll down the menu and select the <strong>\"Add to Home Screen\"</strong> option."
    },
    "label.inst_iphone_step4": {
      "es": "Confirma el nombre de la aplicación (<strong>POCUS Cardíaco</strong>) y toca <strong>\"Agregar\"</strong> en la esquina superior derecha.",
      "en": "Confirm the name of the app (<strong>Cardiac POCUS</strong>) and tap <strong>\"Add\"</strong> in the upper right corner."
    },
    "label.inst_iphone_step5": {
      "es": "Busca el icono de la aplicación en tu pantalla de inicio y ábrela.",
      "en": "Find the app icon on your home screen and open it."
    },
    "label.pwa_note_title": {
      "es": "Nota de la PWA",
      "en": "PWA Note"
    },
    "label.pwa_note_text": {
      "es": "Después de abrir la aplicación por primera vez con conexión a Internet, todos los datos médicos clínicos quedarán almacenados de manera segura en la memoria de tu dispositivo. Podrás consultarla sin conexión de red en cualquier momento.",
      "en": "After opening the app for the first time with an Internet connection, all clinical medical data will be securely stored in your device's memory. You can consult it offline at any time."
    }
